NEXT_PUBLIC_BASE_URL=your_url

DATABASE_URL=i_use_neon
PAYLOAD_SECRET=use_this_https://payloadsecret.com/

# Cloudflare R2 S3 API endpoint for uploads.
R2_BUCKET=my-bucket
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com

# Public custom domain or temporary r2.dev URL for serving files.
R2_PUBLIC_URL=https://media.yourdomain.com
